PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/modern_b2c_ecommerce
JWT_SECRET=replace_with_strong_access_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
NEWSLETTER_FROM_EMAIL=Glow <your_email@gmail.com>
NEWSLETTER_REPLY_TO=your_email@gmail.com
CONTACT_RECEIVER_EMAIL=your_email@gmail.com
